# Copy these into Railway Variables or a local .env file.
# Never commit real passwords, app passwords, or production secrets.

SECRET_KEY=replace-with-a-long-random-django-secret
DEBUG=False

ALLOWED_HOSTS=.up.railway.app,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://*.up.railway.app,http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
